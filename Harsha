  </main>

<script>
(function(){
  var deck=document.getElementById('deck'),slides=[].slice.call(document.querySelectorAll('.slide'));
  var prog=document.getElementById('progress'),hint=document.getElementById('hint');
  var bgm=document.getElementById('bgm'),soundBtn=document.getElementById('sound');
  var reduce=matchMedia('(prefers-reduced-motion: reduce)').matches;

  try{var q=new URLSearchParams(location.search),fr=q.get('from'),nm=q.get('name');
    if(fr) document.getElementById('sign').textContent='— '+fr;
    if(nm){document.querySelectorAll('[data-name]').forEach(function(e){e.innerHTML=nm+'<span class="heart">♥</span>'});}
  }catch(e){}

  var set=['🎈','🎉','✨','💖','🌸','🎂','💫','🥳','🩷','⭐','🧁','💕','🌹'];
  var ef=document.getElementById('emojis');
  if(!reduce){for(var j=0;j<15;j++){var s=document.createElement('span');
    s.textContent=set[(Math.random()*set.length)|0];
    s.style.left=(Math.random()*100)+'%';s.style.fontSize=(16+Math.random()*22)+'px';
    s.style.animationDuration=(13+Math.random()*13)+'s';s.style.animationDelay=(-Math.random()*20)+'s';
    ef.appendChild(s);}}

  slides.forEach(function(){var b=document.createElement('b');b.innerHTML='<i></i>';prog.appendChild(b)});
  var bars=[].slice.call(prog.children);
  function setActive(i){slides.forEach(function(s,k){s.classList.toggle('on',k===i)});
    bars.forEach(function(b,k){b.classList.toggle('done',k<i);b.classList.toggle('on',k===i)});
    hint.classList.toggle('hide',i===slides.length-1);prog.classList.toggle('hide',i===0);
    if(slides[i].classList.contains('finale'))burst();}
  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting&&e.intersectionRatio>0.55)setActive(slides.indexOf(e.target));});},{root:deck,threshold:[0.55]});
  slides.forEach(function(s){io.observe(s)});
  function go(i){if(slides[i])slides[i].scrollIntoView()}
  function curr(){return bars.findIndex(function(b){return b.classList.contains('on')})}

  var started=false,wantSound=true,baseVol=0.6,allowAudio=false,ac=null;
  function ramp(t,ms){var v0=bgm.volume,t0=performance.now();function st(n){var k=Math.min(1,(n-t0)/ms);bgm.volume=v0+(t-v0)*k;if(k<1)requestAnimationFrame(st)}requestAnimationFrame(st);}
  function startAudio(){if(!allowAudio||started||!wantSound)return;bgm.volume=0;var p=bgm.play();
    if(p&&p.then){p.then(function(){started=true;ramp(baseVol,900)}).catch(function(){});}else{started=true;bgm.volume=baseVol;}}
  ['pointerdown','touchstart','keydown'].forEach(function(ev){window.addEventListener(ev,startAudio,{passive:true})});
  soundBtn.addEventListener('click',function(e){e.stopPropagation();wantSound=!wantSound;
    if(wantSound){soundBtn.textContent='♪';if(!started)startAudio();else{bgm.muted=false;if(bgm.paused)bgm.play();}}else{soundBtn.textContent='🔇';bgm.muted=true;}});

  document.getElementById('startBtn').addEventListener('click',function(){startAudio();go(1)});
  document.querySelectorAll('.next').forEach(function(b){b.addEventListener('click',function(){go(curr()+1)})});
  document.getElementById('replay').addEventListener('click',function(){go(0);restartBumper();});
  deck.addEventListener('scroll',function(){hint.style.opacity=deck.scrollTop>40?'0':''},{passive:true});
  window.addEventListener('keydown',function(e){var i=curr();
    if(['ArrowDown','PageDown',' '].includes(e.key)){e.preventDefault();go(i+1)}
    if(['ArrowUp','PageUp'].includes(e.key)){e.preventDefault();go(i-1)}});

  // ---- intro bumper + sting (original homage, not a copy) ----
  var bumper=document.getElementById('bumper');
  function playSting(){
    try{ac=ac||new (window.AudioContext||window.webkitAudioContext)();}catch(e){return;}
    if(ac.state==='suspended')ac.resume();
    var t=ac.currentTime;
    function hit(start,freq,peak,len){var o=ac.createOscillator(),g=ac.createGain();o.type='sine';
      o.frequency.setValueAtTime(freq*1.5,start);o.frequency.exponentialRampToValueAtTime(freq,start+0.12);
      g.gain.setValueAtTime(0.0001,start);g.gain.linearRampToValueAtTime(peak,start+0.012);g.gain.exponentialRampToValueAtTime(0.001,start+len);
      o.connect(g).connect(ac.destination);o.start(start);o.stop(start+len+0.05);}
    function stab(start,freq,peak,len){var o=ac.createOscillator(),g=ac.createGain();o.type='triangle';o.frequency.value=freq;
      g.gain.setValueAtTime(0.0001,start);g.gain.linearRampToValueAtTime(peak,start+0.02);g.gain.exponentialRampToValueAtTime(0.001,start+len);
      o.connect(g).connect(ac.destination);o.start(start);o.stop(start+len+0.05);}
    function noise(start,len,peak){var n=(ac.sampleRate*len)|0,buf=ac.createBuffer(1,n,ac.sampleRate),d=buf.getChannelData(0);
      for(var i=0;i<n;i++)d[i]=(Math.random()*2-1)*(1-i/n);var src=ac.createBufferSource();src.buffer=buf;
      var g=ac.createGain();g.gain.value=peak;var f=ac.createBiquadFilter();f.type='lowpass';f.frequency.value=850;
      src.connect(f).connect(g).connect(ac.destination);src.start(start);}
    hit(t,73.42,0.5,0.5); noise(t,0.14,0.22);
    hit(t+0.19,110,0.6,0.85); stab(t+0.19,659.25,0.16,0.5);
  }
  function runBumper(){
    bumper.classList.remove('gone');void bumper.offsetWidth;bumper.classList.add('play');
    setTimeout(playSting,1500);
    setTimeout(function(){bumper.classList.add('gone');allowAudio=true;startAudio();go(0);},3300);
  }
  function startBumperOnce(){if(bumper.dataset.run)return;bumper.dataset.run='1';runBumper();}
  function restartBumper(){bumper.dataset.run='1';bumper.classList.remove('gone','play');runBumper();}
  bumper.addEventListener('click',startBumperOnce);
  if(reduce){bumper.classList.add('gone');allowAudio=true;go(0);}
  else{startBumperOnce();}   /* auto-play on open, no tap needed */

  // ---- toast (My List) ----
  var toast=document.getElementById('toast'),toastT=null;
  function showToast(html){toast.innerHTML=html;toast.classList.add('show');clearTimeout(toastT);toastT=setTimeout(function(){toast.classList.remove('show')},3200);}
  var listBtn=document.getElementById('listBtn');
  if(listBtn) listBtn.addEventListener('click',function(){showToast("You're already in <b>My List</b> — on repeat mode 🔁💿");});

  // interactive cake
  var cake=document.getElementById('cake'),cglow=document.getElementById('cglow'),cmsg=document.getElementById('cakeMsg');
  var bC=document.getElementById('btnCake'),bL=document.getElementById('btnLight'),bS=document.getElementById('btnSong');
  var lit=false,sang=false;
  bC.addEventListener('click',function(){cake.classList.add('show');bC.disabled=true;bL.disabled=false;cmsg.textContent='Yaaay! 🎉 Ab mombattiyaan jalayein?';partyBurst(0.55);});
  bL.addEventListener('click',function(){cake.classList.add('lit');cglow.style.opacity='1';lit=true;bL.disabled=true;bS.disabled=false;cmsg.textContent='Roshni ho gayi 🕯️ Ab ek wish maang le… 🌟';});
  bS.addEventListener('click',function(){if(sang)return;sang=true;bS.disabled=true;cmsg.textContent='🎶 …🎶';playHBD(function(){cmsg.textContent='Ab phoonk maar ke bujha de! 🎂';cake.classList.add('ready');});});
  cake.addEventListener('click',function(){if(lit&&cake.classList.contains('ready')&&!cake.classList.contains('blown')){cake.classList.add('blown');cglow.style.opacity='0';cmsg.textContent='Happy Birthday, Harsha! 💖🥳';partyBurst(1);}});

  function playHBD(done){
    try{ac=ac||new (window.AudioContext||window.webkitAudioContext)();}catch(e){if(done)done();return;}
    if(ac.state==='suspended')ac.resume();
    ramp(0.12,400);
    var N={G4:392,A4:440,B4:493.88,C5:523.25,D5:587.33,E5:659.25,F5:698.46,G5:783.99};
    var seq=[['G4',.5],['G4',.5],['A4',1],['G4',1],['C5',1],['B4',2],
            ['G4',.5],['G4',.5],['A4',1],['G4',1],['D5',1],['C5',2],
            ['G4',.5],['G4',.5],['G5',1],['E5',1],['C5',1],['B4',1],['A4',1],
            ['F5',.5],['F5',.5],['E5',1],['C5',1],['D5',1],['C5',2]];
    var beat=0.42,t=ac.currentTime+0.08;
    seq.forEach(function(n){var f=N[n[0]],d=n[1]*beat;
      var o=ac.createOscillator(),g=ac.createGain();
      o.type='triangle';o.frequency.value=f;
      g.gain.setValueAtTime(0.0001,t);g.gain.linearRampToValueAtTime(0.22,t+0.04);g.gain.exponentialRampToValueAtTime(0.001,t+d*0.92);
      o.connect(g).connect(ac.destination);o.start(t);o.stop(t+d);t+=d;});
    setTimeout(function(){ramp(wantSound?baseVol:0,700);if(done)done();},(t-ac.currentTime+0.15)*1000);
  }

  var cv=document.getElementById('confetti'),cx=cv.getContext('2d'),W,H,parts=[],run=false;
  function size(){W=cv.width=innerWidth;H=cv.height=innerHeight}size();addEventListener('resize',size);
  var COL=['#e50914','#ff3b46','#ffffff','#b20710','#ffd1d4'];
  function spawn(n,scale){for(var i=0;i<n;i++){parts.push({x:W/2+(Math.random()-.5)*150,y:H*0.36,vx:(Math.random()-.5)*10,vy:Math.random()*-12-4,g:.28+Math.random()*.15,s:(6+Math.random()*8)*(scale||1),c:COL[(Math.random()*COL.length)|0],r:Math.random()*6,vr:(Math.random()-.5)*.4,a:1})}if(!run){run=true;tick()}}
  function burst(){if(reduce)return;spawn(140,1)}
  function partyBurst(k){if(reduce)return;spawn(Math.round(120*(k||1)),1)}
  function tick(){cx.clearRect(0,0,W,H);parts.forEach(function(p){p.vy+=p.g;p.x+=p.vx;p.y+=p.vy;p.r+=p.vr;p.a-=.006;cx.save();cx.globalAlpha=Math.max(0,p.a);cx.translate(p.x,p.y);cx.rotate(p.r);cx.fillStyle=p.c;cx.fillRect(-p.s/2,-p.s/2,p.s,p.s*1.6);cx.restore()});parts=parts.filter(function(p){return p.a>0&&p.y<H+40});if(parts.length)requestAnimationFrame(tick);else{run=false;cx.clearRect(0,0,W,H)}}
})();
</script>
