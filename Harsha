<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1" />
<meta name="theme-color" content="#000000" />
<title>HARSHA — A cine_laxman Original</title>
<meta name="description" content="A cinematic birthday original, made only for Harsha." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Caveat:wght@600;700&family=Kaushan+Script&family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
<style>
  :root{
    --red:#e50914; --red2:#b20710; --redhi:#ff3b46;
    --redgrad:linear-gradient(120deg,var(--redhi),var(--red) 55%,var(--red2));
    --bg:#000; --white:#f5f5f5; --mut:#b8b8b8; --green:#46d369;
    --bp:linear-gradient(120deg,#5ad1ff,#9b8cff 45%,#ff7bc5 100%);
    --col:min(480px,100%);
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{margin:0;height:100%;background:#000;color:var(--white)}
  body{font-family:"Poppins",system-ui,-apple-system,sans-serif;overflow:hidden;-webkit-font-smoothing:antialiased}

  /* exact-netflix: flat black + faint red depth */
  .aura{position:fixed;inset:0;z-index:0;pointer-events:none}
  .aura::before{content:"";position:absolute;width:90vw;height:60vh;left:50%;top:-12vh;transform:translateX(-50%);
    background:radial-gradient(circle,rgba(229,9,20,.22),transparent 65%);filter:blur(60px)}
  .vign{position:fixed;inset:0;z-index:1;pointer-events:none;background:radial-gradient(130% 90% at 50% 0%,transparent 46%,rgba(0,0,0,.82) 100%)}
  .grain{position:fixed;inset:0;z-index:2;pointer-events:none;opacity:.05;mix-blend-mode:screen;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>")}

  .emojis{position:fixed;inset:0;z-index:3;pointer-events:none;overflow:hidden}
  .emojis span{position:absolute;bottom:-10%;opacity:0;animation:floatUp linear infinite;filter:drop-shadow(0 4px 8px rgba(0,0,0,.4))}
  @keyframes floatUp{0%{opacity:0;transform:translateY(0) rotate(0)}10%{opacity:.8}90%{opacity:.8}100%{opacity:0;transform:translateY(-116svh) rotate(36deg)}}

  .progress{position:fixed;top:0;left:50%;transform:translateX(-50%);width:var(--col);z-index:60;display:flex;gap:4px;padding:10px 14px calc(10px + env(safe-area-inset-top))}
  .progress b{flex:1;height:3px;border-radius:3px;background:rgba(255,255,255,.22);overflow:hidden}
  .progress b i{display:block;height:100%;width:0;background:var(--red);transition:width .4s}
  .progress b.done i,.progress b.on i{width:100%}
  .progress.hide{opacity:0;pointer-events:none;transition:opacity .5s}

  .sound{position:fixed;top:calc(14px + env(safe-area-inset-top));right:14px;z-index:70;width:42px;height:42px;border-radius:50%;border:1px solid rgba(255,255,255,.25);background:rgba(0,0,0,.5);backdrop-filter:blur(6px);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .sound:active{transform:scale(.94)}

  .deck{position:relative;z-index:5;height:100svh;overflow-y:scroll;scroll-snap-type:y mandatory;scroll-behavior:smooth;-webkit-overflow-scrolling:touch;scrollbar-width:none}
  .deck::-webkit-scrollbar{display:none}
  .slide{height:100svh;scroll-snap-align:start;scroll-snap-stop:always;position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:74px 22px 92px;text-align:center}
  .col{width:var(--col);margin:0 auto;display:flex;flex-direction:column;align-items:center}

  .eyebrow{font-size:12px;letter-spacing:.3em;text-transform:uppercase;color:var(--red);font-weight:600;margin:0 0 14px}
  .eyebrow.w{color:var(--mut)}
  h2{font-family:"Anton",sans-serif;font-weight:400;letter-spacing:.01em;font-size:clamp(30px,9vw,46px);line-height:1.02;margin:0;text-transform:uppercase}
  p{margin:0;color:var(--mut);font-size:16px;line-height:1.65}
  .lead{color:#ededed;font-size:17px}

  /* hand-painted "with love"-style name lettering */
  .namewrap{display:flex;flex-direction:column;align-items:center;line-height:.9}
  .withlove{font-family:"Caveat",cursive;font-weight:700;font-size:clamp(22px,7vw,34px);color:#fff;transform:rotate(-5deg);margin-bottom:-6px;opacity:.95}
  .script{font-family:"Kaushan Script",cursive;color:var(--red);line-height:.95;
    text-shadow:0 0 30px rgba(229,9,20,.55),0 2px 0 rgba(0,0,0,.4)}
  .name{font-size:clamp(60px,22vw,140px);position:relative;display:inline-flex;align-items:flex-start;gap:.06em}
  .heart{font-family:"Poppins";font-size:.34em;background:var(--bp);-webkit-background-clip:text;background-clip:text;color:transparent;transform:translateY(.55em);filter:drop-shadow(0 0 14px rgba(120,150,255,.6));animation:beat 1.4s ease-in-out infinite}
  @keyframes beat{0%,100%{transform:translateY(.55em) scale(1)}50%{transform:translateY(.55em) scale(1.18)}}
  .swash{width:min(70vw,300px);height:22px;margin-top:2px;overflow:visible}
  .swash path{stroke:var(--red);stroke-width:4;fill:none;stroke-linecap:round;stroke-dasharray:380;stroke-dashoffset:380}
  .slide.on .swash path{animation:draw 1s ease .5s forwards}
  @keyframes draw{to{stroke-dashoffset:0}}

  .rv{opacity:0;transform:translateY(26px);transition:opacity .7s ease,transform .7s cubic-bezier(.2,.7,.2,1)}
  .slide.on .rv{opacity:1;transform:none;transition-delay:calc(var(--i,0)*120ms)}

  /* INTRO */
  .intro.on .namewrap{animation:zoomin 1.4s cubic-bezier(.2,.7,.2,1) both}
  @keyframes zoomin{0%{opacity:0;transform:scale(1.35)}60%{opacity:1}100%{opacity:1;transform:scale(1)}}
  .intro .sub{margin-top:16px;font-size:11px;letter-spacing:.4em;color:var(--mut);text-transform:uppercase}
  .play{margin-top:30px;display:inline-flex;align-items:center;gap:10px;border:0;cursor:pointer;font-family:"Poppins";font-weight:600;font-size:17px;color:#000;background:#fff;padding:13px 30px;border-radius:6px}
  .play:active{transform:translateY(1px)}

  /* CAKE */
  .cakewrap{position:relative;height:240px;display:flex;align-items:flex-end;justify-content:center;margin:10px 0 6px}
  .cglow{position:absolute;left:50%;top:38%;transform:translate(-50%,-50%);width:260px;height:260px;border-radius:50%;background:radial-gradient(circle,rgba(255,184,92,.55),transparent 62%);opacity:0;transition:opacity .6s;pointer-events:none}
  .cake{position:relative;width:200px;opacity:0;transform:scale(.2) translateY(24px);transition:transform .7s cubic-bezier(.2,1.5,.4,1),opacity .5s}
  .cake.show{opacity:1;transform:none}
  .candles{position:absolute;top:-44px;left:0;right:0;display:flex;justify-content:center;gap:38px;z-index:3}
  .candle{width:8px;height:46px;border-radius:3px;background:repeating-linear-gradient(45deg,#fff 0 5px,#ff7bc5 5px 10px)}
  .flame{position:absolute;top:-17px;left:50%;width:13px;height:19px;border-radius:50% 50% 50% 50%/62% 62% 40% 40%;background:radial-gradient(circle at 50% 72%,#fff,#ffd54a 42%,#ff8a00 82%);box-shadow:0 0 18px #ffb74d;transform:translateX(-50%) scale(0);transform-origin:bottom;transition:transform .25s}
  .cake.lit .flame{transform:translateX(-50%) scale(1);animation:flick .26s ease-in-out infinite alternate}
  .cake.blown .flame{transform:translateX(-50%) scale(0)!important;animation:none}
  @keyframes flick{from{transform:translateX(-50%) scale(.96) rotate(-4deg)}to{transform:translateX(-52%) scale(1.1) rotate(4deg)}}
  .icing{height:36px;border-radius:18px 18px 8px 8px;background:var(--bp);position:relative;z-index:2;box-shadow:0 5px 0 rgba(120,150,255,.55)}
  .cbody{height:78px;border-radius:6px 6px 16px 16px;background:linear-gradient(#d8b28a,#8a5a34);box-shadow:inset 0 0 0 2px rgba(255,123,197,.45)}
  .plate{height:14px;margin-top:-2px;border-radius:50%;background:radial-gradient(circle,#fff,#cfcfcf);transform:scaleX(1.5)}
  .cakemsg{margin:4px 0 14px;color:#ededed;font-weight:500;min-height:22px}
  .cakebtns{display:flex;flex-direction:column;gap:10px;width:100%;max-width:300px;margin:0 auto}
  .cbtn{border:0;cursor:pointer;font-family:"Poppins";font-weight:600;font-size:15px;padding:13px 18px;border-radius:8px;color:#fff;background:var(--bp);box-shadow:0 8px 22px -10px rgba(120,150,255,.8);transition:opacity .2s,filter .2s,transform .1s}
  .cbtn:disabled{opacity:.35;cursor:default;filter:grayscale(.5);box-shadow:none}
  .cbtn:not(:disabled):active{transform:translateY(1px)}

  /* TITLE */
  .title .bug{font-family:"Anton";font-size:13px;letter-spacing:.06em;display:flex;align-items:center;gap:8px;margin-bottom:6px;color:var(--red)}
  .title .bug span{color:var(--mut);font-family:"Poppins";font-weight:600;letter-spacing:.34em;font-size:11px}
  .title .name{font-size:clamp(54px,18vw,104px)}
  .title .meta{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;align-items:center;margin:16px 0 4px;font-size:13px;color:var(--mut)}
  .title .match{color:var(--green);font-weight:600}
  .title .pill{border:1px solid rgba(255,255,255,.3);padding:1px 7px;border-radius:3px;font-size:11px;color:#ddd}
  .title .syn{margin:16px 0 22px;max-width:30ch}
  .title .khaas{font-family:"Kaushan Script",cursive;font-size:clamp(26px,8vw,38px);line-height:1.05;color:var(--red);display:block;margin-bottom:6px;text-shadow:0 0 24px rgba(229,9,20,.5)}
  .row{display:flex;gap:10px;justify-content:center}
  .btn{display:inline-flex;align-items:center;gap:9px;border:0;cursor:pointer;font-family:"Poppins";font-weight:600;font-size:15px;padding:12px 22px;border-radius:6px}
  .btn.play{background:#fff;color:#000;margin:0}
  .btn.list{background:rgba(109,109,110,.55);color:#fff}

  /* RECAP */
  .recap .col{align-items:stretch}
  .recap .line{font-size:clamp(19px,5.6vw,25px);line-height:1.4;color:#efefef;margin:8px 0;font-weight:400}
  .recap .hl{font-weight:700;background:var(--bp);-webkit-background-clip:text;background-clip:text;color:transparent}

  /* EPISODES HEADER */
  .ephead .ua{display:inline-flex;align-items:center;gap:8px;font-size:12px;color:var(--mut);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);padding:7px 13px;border-radius:999px;margin-bottom:18px}
  .ephead .ua i{width:7px;height:7px;border-radius:50%;background:var(--red);box-shadow:0 0 10px var(--red)}
  .ephead h2{color:#fff}
  .ephead h2 em{font-style:normal;color:var(--red)}
  .ephead p{max-width:32ch}

  /* EPISODE */
  .ep .stage{position:relative;width:100%;max-width:330px}
  .ep .tag{position:absolute;top:10px;left:10px;z-index:3;font-family:"Anton";font-size:12px;letter-spacing:.08em;color:#fff;background:rgba(0,0,0,.6);border:1px solid rgba(255,255,255,.18);padding:4px 9px;border-radius:4px}
  .ep .tag b{color:var(--red)}
  .ep .frame{width:100%;border-radius:6px;overflow:hidden;background:#000;border:1px solid rgba(255,255,255,.1);box-shadow:0 24px 60px -24px rgba(0,0,0,.9)}
  .ep .frame img{display:block;width:100%;max-height:60svh;object-fit:contain}
  .ep .bar{margin-top:14px;width:64px;height:3px;border-radius:3px;background:var(--red)}
  .ep .cap{margin-top:14px;font-family:"Kaushan Script",cursive;font-size:clamp(20px,6vw,26px);color:var(--red);max-width:24ch;text-shadow:0 0 20px rgba(229,9,20,.4)}

  /* TREK */
  .trek .badge{font-size:42px;margin-bottom:8px}
  .trek h2{color:#fff}
  .trek h2 em{font-style:normal;color:var(--red)}
  .trek p{max-width:30ch}
  .trek .bright{font-family:"Kaushan Script",cursive;font-size:clamp(21px,6.4vw,28px);line-height:1.25;margin:16px 0 4px;color:var(--red);text-shadow:0 0 22px rgba(229,9,20,.45)}

  /* FINALE */
  .finale .card{background:linear-gradient(180deg,rgba(18,18,18,.78),rgba(0,0,0,.5));border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:32px 24px}
  .finale .hb{font-family:"Caveat",cursive;font-weight:700;font-size:clamp(24px,7.5vw,34px);color:#fff;transform:rotate(-4deg);margin-bottom:-4px;display:block}
  .finale .name{font-size:clamp(46px,15vw,80px);justify-content:center}
  .finale .msg{margin:16px 0;max-width:32ch}
  .finale .bright{font-family:"Kaushan Script",cursive;font-size:clamp(22px,6.6vw,30px);line-height:1.25;margin:6px 0 2px;color:var(--red);text-shadow:0 0 22px rgba(229,9,20,.45)}
  .sign{margin-top:16px;color:var(--mut);font-style:italic}
  .finale .btn.play{margin-top:22px}

  .hint{position:fixed;left:50%;bottom:calc(18px + env(safe-area-inset-bottom));transform:translateX(-50%);z-index:55;display:flex;flex-direction:column;align-items:center;gap:3px;color:var(--mut);font-size:10px;letter-spacing:.22em;text-transform:uppercase;transition:opacity .4s;pointer-events:none}
  .hint .chev{width:18px;height:18px;border-right:2px solid var(--red);border-bottom:2px solid var(--red);transform:rotate(45deg);animation:bob 1.6s ease-in-out infinite}
  .hint.hide{opacity:0}
  @keyframes bob{0%,100%{transform:rotate(45deg) translate(0,0)}50%{transform:rotate(45deg) translate(4px,4px)}}

  /* intro bumper (cinematic 'H' homage + sting) */
  .bumper{position:fixed;inset:0;z-index:200;background:#000;display:flex;align-items:center;justify-content:center;transition:opacity .6s}
  .bumper.gone{opacity:0;pointer-events:none}
  .bletter{font-family:"Anton",sans-serif;font-size:min(48vh,58vw);line-height:1;position:relative;transform:scale(.55);opacity:0;
    background:repeating-linear-gradient(90deg,#7a060c 0 5px,#e50914 5px 11px,#ff5560 11px 16px);background-size:200% 100%;
    -webkit-background-clip:text;background-clip:text;color:transparent;filter:drop-shadow(0 0 44px rgba(229,9,20,.55))}
  .bumper.play .bletter{animation:bgrow 3.3s cubic-bezier(.2,.7,.2,1) forwards, bstripe 3.3s linear forwards}
  @keyframes bgrow{0%{opacity:0;transform:scale(.55)}16%{opacity:1}55%{transform:scale(1)}70%{transform:scale(1.05)}100%{opacity:1;transform:scale(1)}}
  @keyframes bstripe{0%{background-position:0 0}100%{background-position:200% 0}}
  .bletter::after{content:"H";position:absolute;inset:0;background:linear-gradient(100deg,transparent 38%,rgba(255,255,255,.95) 50%,transparent 62%);background-size:300% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;background-position:160% 0;opacity:0}
  .bumper.play .bletter::after{animation:bshine 1.1s ease 1.5s both}
  @keyframes bshine{0%{opacity:0;background-position:160% 0}30%{opacity:1}100%{opacity:0;background-position:-60% 0}}
  .bflash{position:fixed;inset:0;background:#fff;opacity:0;pointer-events:none}
  .bumper.play .bflash{animation:bflash .5s ease 1.5s both}
  @keyframes bflash{0%{opacity:0}14%{opacity:.85}100%{opacity:0}}
  .btap{position:absolute;bottom:13%;left:50%;transform:translateX(-50%);color:#fff;font-weight:600;letter-spacing:.18em;font-size:13px;text-transform:uppercase;opacity:.85;animation:tappulse 1.6s ease-in-out infinite}
  @keyframes tappulse{0%,100%{opacity:.45}50%{opacity:1}}
  .bumper.play .btap{display:none}

  /* toast */
  .toast{position:fixed;left:50%;bottom:calc(64px + env(safe-area-inset-bottom));transform:translateX(-50%) translateY(14px);z-index:80;
    background:rgba(20,20,20,.92);border:1px solid rgba(255,255,255,.16);color:#fff;font-weight:600;font-size:14px;
    padding:12px 18px;border-radius:10px;max-width:84vw;text-align:center;opacity:0;pointer-events:none;
    box-shadow:0 12px 30px -10px rgba(0,0,0,.8);transition:opacity .35s,transform .35s}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  .toast b{color:#e50914}

  #confetti{position:fixed;inset:0;z-index:50;pointer-events:none}

  @media (prefers-reduced-motion: reduce){
    *{animation:none!important}
    .swash path{stroke-dashoffset:0!important}
    .rv{transition:opacity .4s!important;transform:none!important}
    .deck{scroll-behavior:auto}
  }
</style>
</head>
<body>
  <div class="bumper" id="bumper" role="button" aria-label="Tap to start">
    <div class="bletter">H</div>
    <div class="bflash"></div>
  </div>
  <div class="toast" id="toast" aria-live="polite"></div>

  <div class="aura" aria-hidden="true"></div>
  <div class="vign" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>
  <div class="emojis" id="emojis" aria-hidden="true"></div>
  <canvas id="confetti" aria-hidden="true"></canvas>

  <audio id="bgm" loop preload="auto" playsinline><source src="data:audio/mpeg;base64," type="audio/mpeg"></audio>
  <button class="sound" id="sound" type="button" aria-label="Toggle music">♪</button>

  <div class="progress" id="progress" aria-hidden="true"></div>
  <div class="hint" id="hint"><div class="chev"></div><span>slide up</span></div>

  <main class="deck" id="deck">

    <!-- 1 INTRO -->
    <section class="slide intro on" data-label="Intro">
      <div class="col">
        <div class="namewrap">
          <span class="withlove">happy birthday</span>
          <div class="script name" data-name>Harsha<span class="heart">♥</span></div>
          <svg class="swash" viewBox="0 0 300 22"><path d="M6 14 C 70 2, 230 2, 294 12"/></svg>
        </div>
        <div class="sub">a cine_laxman original</div>
        <button class="play" id="startBtn" type="button"><span>▶</span> Play</button>
      </div>
    </section>

    <!-- 2 CAKE -->
    <section class="slide cake-s" data-label="Cake">
      <div class="col">
        <p class="eyebrow rv" style="--i:0">before we begin… 🎂</p>
        <div class="cakewrap rv" style="--i:1">
          <div class="cglow" id="cglow"></div>
          <div class="cake" id="cake">
            <div class="candles"><div class="candle"><span class="flame"></span></div><div class="candle"><span class="flame"></span></div><div class="candle"><span class="flame"></span></div></div>
            <div class="icing"></div><div class="cbody"></div><div class="plate"></div>
          </div>
        </div>
        <p class="cakemsg rv" id="cakeMsg" style="--i:2">Niche button dabaa ke shuru kar 👇</p>
        <div class="cakebtns rv" style="--i:3">
          <button class="cbtn" id="btnCake" type="button">🎂 Here's your cake</button>
          <button class="cbtn" id="btnLight" type="button" disabled>🕯️ Lighten up the lights</button>
          <button class="cbtn" id="btnSong" type="button" disabled>🎵 Play Happy Birthday</button>
        </div>
      </div>
    </section>

    <!-- 3 TITLE -->
    <section class="slide title" data-label="Title">
      <div class="col">
        <div class="bug rv" style="--i:0">cine_laxman <span>original</span></div>
        <div class="script name" data-name style="--i:1">Harsha<span class="heart">♥</span></div>
        <div class="meta rv" style="--i:2"><span class="match">98% Match</span><span>2026</span><span class="pill">U/A · Wholesome</span><span>1 Season</span></div>
        <div class="meta rv" style="--i:3"><span>Feel‑Good · Friendship · Birthday Special</span></div>
        <p class="lead syn rv" style="--i:4"><span class="khaas">Dost, tu khaas hai 💖</span>Aaj tera din hai — slide up aur press play ✨</p>
        <div class="row rv" style="--i:5"><button class="btn play next" type="button"><span>▶</span> Play</button><button class="btn list" id="listBtn" type="button">＋ My List</button></div>
      </div>
    </section>

    <!-- 4 RECAP -->
    <section class="slide recap" data-label="The plot">
      <div class="col">
        <p class="eyebrow rv" style="--i:0">the whole plot, in one line 💌</p>
        <p class="line rv" style="--i:1">Teri hasi se… <span class="hl">fark padta hai.</span> 😄</p>
        <p class="line rv" style="--i:2">Teri smiley‑laugh‑heart emoji se… <span class="hl">fark padta hai.</span> 🥹</p>
        <p class="line rv" style="--i:3">Teri awaaz sunne se… <span class="hl">fark padta hai.</span> 🎧</p>
        <p class="line rv" style="--i:4">Bhale hi wahan purane text na ho… phir bhi unn yaadon se <span class="hl">fark padta hai.</span> ✨</p>
        <p class="line rv" style="--i:5">Bas… tere <span class="hl">hone</span> se fark padta hai. 💜</p>
      </div>
    </section>

    <!-- 5 EPISODES HEADER -->
    <section class="slide ephead" data-label="This season">
      <div class="col">
        <span class="ua rv" style="--i:0"><i></i> Unavailable message</span>
        <h2 class="rv" style="--i:1">This <em>Season</em></h2>
        <p class="lead rv" style="--i:2">Tere purane account ke woh texts ab “Unavailable” kehte hai. Par episodes? Still streaming. 🍿</p>
      </div>
    </section>

    <!-- EPISODES -->
    <section class="slide ep" data-label="E1"><div class="col"><div class="stage rv" style="--i:0"><div class="tag">S1 <b>:</b> E1</div><div class="frame"><img src="data:image/jpeg;base64," alt=""></div></div><div class="bar rv" style="--i:1"></div></div></section>
